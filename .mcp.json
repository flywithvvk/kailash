{
  "mcpServers": {
    "gpdoc": {
      "type": "stdio",
      "command": "node",
      "args": [
        "c:\\Users\\vivek\\.antigravity\\extensions\\repetere.gpdoc-3.0.0-universal\\out\\mcp-server.js"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "gh",
