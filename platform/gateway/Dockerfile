# syntax=docker/dockerfile:1.7
FROM python:3.11-slim
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1
WORKDIR /app

# Shared lib (build context = repo root)
COPY platform /opt/platform
RUN pip install --upgrade pip && pip install /opt/platform

COPY platform/gateway/requirements.txt ./requirements.txt
RUN pip install -r requirements.txt

COPY platform/gateway/app ./app

EXPOSE 8100
HEALTHCHECK --interval=30s --timeout=5s --retries=5 \
  CMD python -c "import urllib.request,sys;sys.exit(0 if urllib.request.urlopen('http://localhost:8100/health').status==200 else 1)"
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8100"]
