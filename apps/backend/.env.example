# KAILASH AEGIS Hub — Backend environment template.
# Copy to `.env` and fill in real values. Do NOT commit `.env`.

# ---------- Database ----------
MONGO_URL=mongodb://localhost:27017
DATABASE_NAME=kailash_aegis

# ---------- Security ----------
SECRET_KEY=change-me-to-a-long-random-string

# ---------- AI provider (choose ONE; OpenRouter takes precedence) ----------

# Option A — OpenRouter (OpenAI-compatible, lets you use many models)
# Docs: https://openrouter.ai/docs
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3-haiku
OPENROUTER_SITE_URL=https://kailash-ai.in
OPENROUTER_APP_NAME=KAILASH AEGIS Hub

# Option B — Direct Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ---------- Vector / RAG (optional) ----------
PINECONE_API_KEY=
PINECONE_INDEX=kailashai
PINECONE_HOST=us-east-1

# ---------- Domain / CORS ----------
BACKEND_URL=https://api.kailash-ai.in
FRONTEND_URL=https://kailash-ai.in
ALLOWED_ORIGINS=https://kailash-ai.in,https://www.kailash-ai.in,https://kailash-38268.web.app,https://kailash-38268.firebaseapp.com

# ---------- Firebase Admin SDK ----------
# Option A — path to service account key JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=
# Option B — inline JSON string (CI/CD friendly, set in GitHub Secrets)
# FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=kailash-38268
FIREBASE_STORAGE_BUCKET=kailash-38268.firebasestorage.app
# Set FIREBASE_DISABLED=true to skip Firebase init
# FIREBASE_DISABLED=false

# ---------- Deployment ----------
# Frontend: Firebase Hosting (project: kailash-38268)
# Backend:  Vultr VPS (docker-compose + nginx reverse proxy)
# Docs:     See deploy/vultr/deploy.sh and apps/frontend/firebase.json
