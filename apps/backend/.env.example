# KAILASH AEGIS Hub — Backend environment template.
# Copy to `.env` and fill in real values. Do NOT commit `.env`.

# ---------- Database ----------
MONGO_URL=mongodb://localhost:27017
DATABASE_NAME=kailash_aegis

# ---------- Security ----------
SECRET_KEY=change-me-to-a-long-random-string

# ---------- AI provider (choose ONE; OpenRouter takes precedence) ----------

# Option A — OpenRouter (OpenAI-compatible, lets you use many models)
# Docs: https://openrouter.ai/docs
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3-haiku
OPENROUTER_SITE_URL=https://kailash-ai.in
OPENROUTER_APP_NAME=KAILASH AEGIS Hub

# Option B — Direct Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ---------- Vector / RAG (optional) ----------
PINECONE_API_KEY=
PINECONE_INDEX=kailashai
PINECONE_HOST=us-east-1

# ---------- Domain / CORS (optional) ----------
BACKEND_URL=
FRONTEND_URL=
ALLOWED_ORIGINS=
